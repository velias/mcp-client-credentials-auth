# =============================================================================
# mcp-client-credentials-auth configuration
# =============================================================================
# All variables use the MCP_CC_PROXY_ prefix.
# Only MCP_CC_PROXY_REMOTE_MCP_URL, MCP_CC_PROXY_CLIENT_ID, and
# MCP_CC_PROXY_CLIENT_SECRET are required.

# Remote MCP server URL (required)
# The URL of the OAuth-protected MCP server to connect to.
# Use https:// in production. http:// is allowed but logs a security warning
# for non-loopback hosts.
MCP_CC_PROXY_REMOTE_MCP_URL=https://mcp.example.com/mcp

# OAuth client_id (required)
MCP_CC_PROXY_CLIENT_ID=my-service-account

# OAuth client_secret (required)
MCP_CC_PROXY_CLIENT_SECRET=changeme

# Proactive token refresh window in seconds (optional, default: 30)
# Token is refreshed this many seconds before expiry.
# MCP_CC_PROXY_REFRESH_SKEW_SECONDS=30

# Upstream request timeout in milliseconds (optional, default: 30000)
# MCP_CC_PROXY_REQUEST_TIMEOUT_MS=30000

# Capabilities polling interval in seconds (optional, default: 60, 0 = disabled)
# Periodically re-fetches tools/resources/prompts from the remote server and
# emits list_changed notifications to the MCP client when changes are detected.
# MCP_CC_PROXY_CAPABILITIES_POLL_SECONDS=60

# Enable debug logging (optional, default: false)
# Writes detailed per-request logs to stderr.
# MCP_CC_PROXY_DEBUG=true
