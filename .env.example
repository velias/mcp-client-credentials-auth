# =============================================================================
# mcp-client-credentials-auth configuration
# =============================================================================
# All variables use the MCP_CC_PROXY_ prefix.
# Only MCP_CC_PROXY_REMOTE_MCP_URL, MCP_CC_PROXY_CLIENT_ID, and
# MCP_CC_PROXY_CLIENT_SECRET are required.

# Remote MCP server URL (required)
# The URL of the OAuth-protected MCP server to connect to.
# Use https:// in production. http:// is allowed but logs a security warning
# for non-loopback hosts.
MCP_CC_PROXY_REMOTE_MCP_URL=https://mcp.example.com/mcp

# OAuth client_id (required)
MCP_CC_PROXY_CLIENT_ID=my-service-account

# OAuth client_secret (required)
MCP_CC_PROXY_CLIENT_SECRET=changeme

# IdP token endpoint URL (optional)
# When set, skips MCP Authorization discovery (RFC 9728 / RFC 8414) and
# requests tokens directly from this URL. Use when the remote MCP server
# accepts Bearer tokens but that discovery is not available.
# Use https:// in production. http:// to a non-loopback host logs a warning
# because the client secret would travel unencrypted.
# MCP_CC_PROXY_TOKEN_ENDPOINT=https://auth.example.com/oauth/token

# OAuth scopes for the token request (optional, space-separated)
# Overrides scopes auto-discovered via MCP Authorization and RFC 9728 / RFC 8414.
# With a manual token endpoint that discovery is skipped, so set this if your
# MCP Server requires scopes.
# MCP_CC_PROXY_SCOPES=inventory.read orders.write

# Proactive token refresh window in seconds (optional, default: 30)
# Token is refreshed this many seconds before expiry.
# MCP_CC_PROXY_REFRESH_SKEW_SECONDS=30

# Upstream request timeout in milliseconds (optional, default: 30000)
# MCP_CC_PROXY_REQUEST_TIMEOUT_MS=30000

# Startup readiness budget in milliseconds (optional, default: 60000)
# Max wall-clock time to obtain a usable access token (when auth is required)
# and reach the remote MCP server before the process exits. Retries for both
# share this single deadline.
# MCP_CC_PROXY_STARTUP_TIMEOUT_MS=60000

# Capabilities polling interval in seconds (optional, default: 60, 0 = disabled)
# Periodically re-fetches tools/resources/prompts from the remote server and
# emits list_changed notifications to the MCP client when changes are detected.
# MCP_CC_PROXY_CAPABILITIES_POLL_SECONDS=60

# OAuth PRM/AS rediscovery interval in seconds (optional, default: 3600)
# Re-fetches RFC 9728 / RFC 8414 metadata on this interval (and after remote
# reconnect). 0 disables the timer only; reconnect-triggered rediscovery remains.
# Skipped when MCP_CC_PROXY_TOKEN_ENDPOINT is set.
# MCP_CC_PROXY_OAUTH_REDISCOVERY_SECONDS=3600

# Local transport (optional, default: stdio)
# Use http for on-premises Streamable HTTP (multi-session). See README On-premises HTTP.
# MCP_CC_PROXY_TRANSPORT=stdio
# MCP_CC_PROXY_TRANSPORT=http

# HTTP listen address (HTTP mode only; defaults: 127.0.0.1:8080/mcp)
# Container image defaults LISTEN_HOST to 0.0.0.0.
# MCP_CC_PROXY_LISTEN_HOST=127.0.0.1
# MCP_CC_PROXY_LISTEN_PORT=8080
# MCP_CC_PROXY_LISTEN_PATH=/mcp

# HTTP session idle timeout in seconds (optional, default: 1800, 0 = disabled)
# Closes sessions with no inbound MCP traffic for this long (orphans after client
# reload without DELETE). Clients must re-initialize after 404 Session not found.
# MCP_CC_PROXY_HTTP_SESSION_IDLE_SECONDS=1800

# Audit tools/resources/prompts invoke + discovery, and server→client
# sampling/createMessage + elicitation/create, to stderr (optional)
# Default: false for stdio, true for http. Override either default explicitly.
# Logs method in msg, plus outcome/durationMs (and tool/uri/prompt when applicable).
# Does not log arguments, sampling prompts, or elicitation bodies. HTTP lines include sessionId.
# resources/read logs the full uri (query/userinfo included); treat sinks like access logs if URIs embed secrets.
# MCP_CC_PROXY_AUDIT_CALLS=true

# Enable debug logging (optional, default: false)
# Writes detailed per-request logs to stderr.
# MCP_CC_PROXY_DEBUG=true
